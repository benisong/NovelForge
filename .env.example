# ===== 服务端口与绑定 =====
# 默认对外开放（0.0.0.0）+ 17000 端口。生产环境请在前面放 Nginx+HTTPS 终止。
# 只允许本机访问时改成 127.0.0.1。
BIND_ADDR=0.0.0.0
PORT=17000

# ===== 数据存储目录（Docker 模式下无需修改）=====
NOVEL_DATA_DIR=/app/data

# ===== 开发模式 =====
DEV_RELOAD=false

# ===== 日志级别（DEBUG / INFO / WARNING / ERROR）=====
LOG_LEVEL=INFO

# ===== CORS（留空表示同源即可）=====
# CORS_ORIGINS=https://example.com
CORS_ORIGINS=

# ===== 多工作空间：管理员入口 =====
# 管理员密码。默认 "admin"。打开 /admin 会要求输入一次，下发 cookie 记 30 天。
# 【⚠️ 公网部署强烈建议改】改成一个随机串再 docker compose up -d --build 即可。
# 例如：openssl rand -hex 12
ADMIN_TOKEN=admin

# ===== 多工作空间：cookie 签名密钥 =====
# 用于为每个工作空间签发登录 cookie。
# 不设置时会自动生成并落到 $NOVEL_DATA_DIR/.cookie_secret（首次启动后持久化）。
# 强烈建议显式设置一个高强度密钥，便于多机部署时一致；例如：openssl rand -hex 48
WORKSPACE_COOKIE_SECRET=

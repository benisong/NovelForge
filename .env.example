# ===== 服务端口与绑定 =====
# 对外开放请改为 0.0.0.0，并确保前置 Nginx/HTTPS 与访问控制
BIND_ADDR=127.0.0.1
PORT=8000

# ===== 数据存储目录（Docker 模式下无需修改）=====
NOVEL_DATA_DIR=/app/data

# ===== 开发模式 =====
# 仅本地开发时开启，生产环境请保持为 false
DEV_RELOAD=false

# ===== 日志级别 =====
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ===== CORS =====
# 若前端与后端不同源，用逗号分隔列出允许的来源；留空表示不开放跨域
# CORS_ORIGINS=https://example.com,https://app.example.com
CORS_ORIGINS=

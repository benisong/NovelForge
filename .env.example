# ===== 服务端口与绑定 =====
# 对外开放请改为 0.0.0.0，并确保前置 Nginx/HTTPS 与访问控制
BIND_ADDR=127.0.0.1
PORT=8000

# ===== 数据存储目录（Docker 模式下无需修改）=====
NOVEL_DATA_DIR=/app/data

# ===== 开发模式 =====
DEV_RELOAD=false

# ===== 日志级别（DEBUG / INFO / WARNING / ERROR）=====
LOG_LEVEL=INFO

# ===== CORS（留空表示同源即可）=====
# CORS_ORIGINS=https://example.com
CORS_ORIGINS=

# ===== 多工作空间：管理员入口 =====
# 访问 /admin?token=<ADMIN_TOKEN> 进管理页（新建/删除/改密码工作空间）
# 必须设置一个高强度随机串（≥32 字符），例如：openssl rand -hex 32
ADMIN_TOKEN=

# ===== 多工作空间：cookie 签名密钥 =====
# 用于为每个工作空间签发登录 cookie。
# 不设置时会自动生成并落到 $NOVEL_DATA_DIR/.cookie_secret（首次启动后持久化）。
# 强烈建议显式设置一个高强度密钥，便于多机部署时一致；例如：openssl rand -hex 48
WORKSPACE_COOKIE_SECRET=
